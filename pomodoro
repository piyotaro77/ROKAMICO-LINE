<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⏱️ もちもちポモドーロ</title>
<link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-work: #fef7f0;
    --bg-break: #f0f7fe;
    --card: #ffffff;
    --pink: #f9a8d4;
    --blue: #93c5fd;
    --peach: #fcd5ce;
    --lavender: #c4b5fd;
    --mint: #a7f3d0;
    --text: #334155;
    --sub: #94a3b8;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'M PLUS Rounded 1c', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    transition: background 0.8s ease;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 20px 0;
  }
  body.work { background: var(--bg-work); }
  body.break { background: var(--bg-break); }
  body.idle { background: #faf5ff; }

.app {
width: 100%;
max-width: 400px;
padding: 20px;
text-align: center;
}

/* Header */
.header-title {
font-size: 20px;
font-weight: 900;
margin-bottom: 2px;
}
body.work .header-title { color: #e879a0; }
body.break .header-title { color: #60a5fa; }
body.idle .header-title { color: var(–lavender); }

.header-sub {
font-size: 11px;
color: var(–sub);
margin-bottom: 16px;
}

/* Status badge */
.status-badge {
display: inline-block;
font-size: 12px;
font-weight: 900;
padding: 5px 18px;
border-radius: 20px;
letter-spacing: 2px;
margin-bottom: 16px;
transition: all 0.5s;
}
body.work .status-badge { background: #fce7f3; color: #db2777; }
body.break .status-badge { background: #dbeafe; color: #2563eb; }
body.idle .status-badge { background: #ede9fe; color: #7c3aed; }

/* Cat area */
.cat-area {
position: relative;
height: 200px;
margin: 8px 0 12px;
display: flex;
align-items: center;
justify-content: center;
}

/* CSS Cat container */
.cat {
display: flex;
flex-direction: column;
align-items: center;
transition: transform 0.5s ease;
cursor: pointer;
}

/* Speech bubble - sits above cat */
.speech {
background: white;
border: 2px solid #e2e8f0;
border-radius: 14px;
padding: 5px 14px;
font-size: 11px;
font-weight: 700;
color: var(–text);
white-space: nowrap;
box-shadow: 0 2px 8px rgba(0,0,0,0.04);
margin-bottom: 8px;
position: relative;
animation: speechBounce 3s ease-in-out infinite;
}
.speech::after {
content: ‘’;
position: absolute;
bottom: -6px;
left: 50%;
transform: translateX(-50%);
width: 0;
height: 0;
border-left: 6px solid transparent;
border-right: 6px solid transparent;
border-top: 6px solid white;
}

@keyframes speechBounce {
0%, 100% { transform: translateY(0); }
50% { transform: translateY(-3px); }
}

/* Cat wrapper - contains all cat parts */
.cat-wrapper {
position: relative;
width: 120px;
height: 120px;
}

/* Cat body */
.cat-body {
width: 100px;
height: 72px;
border-radius: 50px 50px 36px 36px;
position: absolute;
bottom: 0;
left: 50%;
transform: translateX(-50%);
transition: all 0.5s;
}
body.work .cat-body { background: #f3e8ff; border: 3px solid #c4b5fd; }
body.break .cat-body { background: #fce7f3; border: 3px solid #f9a8d4; }
body.idle .cat-body { background: #e8f5e8; border: 3px solid #a7f3d0; }

/* Cat head */
.cat-head {
width: 80px;
height: 68px;
border-radius: 50%;
position: absolute;
top: 16px;
left: 50%;
transform: translateX(-50%);
z-index: 3;
transition: all 0.5s;
}
body.work .cat-head { background: #f3e8ff; border: 3px solid #c4b5fd; }
body.break .cat-head { background: #fce7f3; border: 3px solid #f9a8d4; }
body.idle .cat-head { background: #e8f5e8; border: 3px solid #a7f3d0; }

/* Ears */
.ear {
position: absolute;
width: 0;
height: 0;
z-index: 2;
}
.ear-l {
border-left: 12px solid transparent;
border-right: 12px solid transparent;
top: 6px;
left: 16px;
transition: border-bottom-color 0.5s;
}
.ear-r {
border-left: 12px solid transparent;
border-right: 12px solid transparent;
top: 6px;
right: 16px;
transition: border-bottom-color 0.5s;
}
body.work .ear-l, body.work .ear-r { border-bottom: 22px solid #f3e8ff; }
body.break .ear-l, body.break .ear-r { border-bottom: 22px solid #fce7f3; }
body.idle .ear-l, body.idle .ear-r { border-bottom: 22px solid #e8f5e8; }

.ear-inner-l, .ear-inner-r {
position: absolute;
width: 0;
height: 0;
z-index: 3;
}
.ear-inner-l {
border-left: 7px solid transparent;
border-right: 7px solid transparent;
border-bottom: 14px solid #FFB6C1;
top: 12px;
left: 21px;
}
.ear-inner-r {
border-left: 7px solid transparent;
border-right: 7px solid transparent;
border-bottom: 14px solid #FFB6C1;
top: 12px;
right: 21px;
}

/* Eyes - positioned relative to cat-head */
.eyes {
position: absolute;
top: 22px;
left: 50%;
transform: translateX(-50%);
display: flex;
gap: 18px;
z-index: 4;
}
.eye {
width: 10px;
height: 12px;
background: #334155;
border-radius: 50%;
position: relative;
transition: all 0.3s;
}
.eye::after {
content: ‘’;
width: 4px;
height: 4px;
background: white;
border-radius: 50%;
position: absolute;
top: 2px;
left: 2px;
}

/* Work mode: focused eyes */
body.work .eye {
height: 8px;
border-radius: 50%;
}

/* Break mode: happy closed eyes */
body.break .eye {
height: 3px;
width: 12px;
border-radius: 0 0 12px 12px;
background: #334155;
}
body.break .eye::after { display: none; }

/* Blush */
.blush {
position: absolute;
width: 16px;
height: 8px;
border-radius: 50%;
top: 32px;
z-index: 4;
opacity: 0.4;
transition: opacity 0.5s;
}
.blush-l { left: 4px; background: rgba(255,150,150,0.5); }
.blush-r { right: 4px; background: rgba(255,150,150,0.5); }
body.break .blush { opacity: 0.7; }

/* Mouth */
.mouth {
position: absolute;
top: 40px;
left: 50%;
transform: translateX(-50%);
z-index: 4;
font-size: 14px;
color: #e88;
}
.mouth::before { content: ‘ω’; }
body.break .mouth { font-size: 16px; }

/* Paws */
.paw {
width: 18px;
height: 14px;
border-radius: 50%;
position: absolute;
bottom: 2px;
z-index: 4;
transition: all 0.5s;
}
.paw-l { left: 8px; }
.paw-r { right: 8px; }
body.work .paw { background: #e8d5ff; border: 2px solid #c4b5fd; }
body.break .paw { background: #ffd6e8; border: 2px solid #f9a8d4; }
body.idle .paw { background: #d1fae5; border: 2px solid #a7f3d0; }

/* Tail */
.tail {
position: absolute;
bottom: 10px;
right: -4px;
width: 30px;
height: 16px;
border-bottom: 3px solid;
border-right: 3px solid;
border-radius: 0 0 16px 0;
z-index: 1;
transition: border-color 0.5s;
animation: tailWag 2s ease-in-out infinite;
}
body.work .tail { border-color: #c4b5fd; }
body.break .tail { border-color: #f9a8d4; }
body.idle .tail { border-color: #a7f3d0; }

@keyframes tailWag {
0%, 100% { transform: rotate(-5deg); }
50% { transform: rotate(10deg); }
}

/* Cat animations */
body.work .cat { animation: catFocus 3s ease-in-out infinite; }
body.break .cat { animation: catRoll 4s ease-in-out infinite; }
body.idle .cat { animation: catIdle 5s ease-in-out infinite; }

@keyframes catFocus {
0%, 100% { transform: translateY(0); }
50% { transform: translateY(-4px); }
}

@keyframes catRoll {
0%, 100% { transform: rotate(0deg) translateY(0); }
25% { transform: rotate(-8deg) translateY(-6px); }
50% { transform: rotate(0deg) translateY(0); }
75% { transform: rotate(8deg) translateY(-6px); }
}

@keyframes catIdle {
0%, 100% { transform: translateY(0) scale(1); }
50% { transform: translateY(2px) scale(1.02); }
}

/* Floating particles */
.particles {
position: absolute;
inset: 0;
pointer-events: none;
overflow: hidden;
}
.particle {
position: absolute;
font-size: 14px;
opacity: 0.3;
animation: particleFloat 6s ease-in-out infinite;
}

@keyframes particleFloat {
0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.2; }
50% { transform: translateY(-20px) rotate(10deg); opacity: 0.4; }
}

/* Timer display */
.timer-display {
font-size: 64px;
font-weight: 900;
letter-spacing: 4px;
margin: 8px 0;
transition: color 0.5s;
}
body.work .timer-display { color: #e879a0; }
body.break .timer-display { color: #60a5fa; }
body.idle .timer-display { color: var(–lavender); }

.timer-label {
font-size: 12px;
color: var(–sub);
margin-bottom: 16px;
}

/* Progress ring */
.progress-container {
position: relative;
display: inline-block;
margin-bottom: 16px;
}

.progress-ring {
width: 200px;
height: 200px;
transform: rotate(-90deg);
}
.progress-bg {
fill: none;
stroke: #e2e8f0;
stroke-width: 6;
}
.progress-fill {
fill: none;
stroke-width: 6;
stroke-linecap: round;
transition: stroke-dashoffset 1s linear, stroke 0.5s;
}
body.work .progress-fill { stroke: var(–pink); }
body.break .progress-fill { stroke: var(–blue); }
body.idle .progress-fill { stroke: var(–lavender); }

.progress-inner {
position: absolute;
inset: 0;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
}

/* Controls */
.controls {
display: flex;
gap: 10px;
justify-content: center;
margin-bottom: 16px;
}

.ctrl-btn {
width: 56px;
height: 56px;
border-radius: 50%;
border: 3px solid;
background: var(–card);
font-size: 22px;
cursor: pointer;
transition: all 0.2s;
display: flex;
align-items: center;
justify-content: center;
box-shadow: 0 3px 10px rgba(0,0,0,0.06);
}
.ctrl-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 16px rgba(0,0,0,0.1); }
.ctrl-btn:active { transform: scale(0.95); }

.ctrl-btn.primary {
width: 68px;
height: 68px;
font-size: 26px;
}
body.work .ctrl-btn { border-color: var(–pink); }
body.break .ctrl-btn { border-color: var(–blue); }
body.idle .ctrl-btn { border-color: var(–lavender); }

/* Time presets */
.presets {
display: flex;
gap: 6px;
justify-content: center;
margin-bottom: 12px;
}
.preset-btn {
padding: 6px 14px;
border-radius: 16px;
border: 2px solid var(–lavender);
background: white;
font-family: ‘M PLUS Rounded 1c’, sans-serif;
font-size: 11px;
font-weight: 700;
color: var(–text);
cursor: pointer;
transition: all 0.2s;
}
.preset-btn:hover { background: #ede9fe; }
.preset-btn.active { background: var(–lavender); color: white; }

/* Session counter */
.session-section {
background: #f0ecf9;
border: 2px solid #d8d0ec;
border-radius: 16px;
padding: 12px 16px;
margin-bottom: 8px;
}
.session-section-label {
font-size: 11px;
font-weight: 900;
color: #7c3aed;
letter-spacing: 2px;
margin-bottom: 8px;
}
.sessions {
display: flex;
gap: 8px;
justify-content: center;
margin-bottom: 8px;
}
.session-dot {
width: 12px;
height: 12px;
border-radius: 50%;
border: 2px solid #b8aed0;
background: #e0daf0;
transition: all 0.3s;
}
.session-dot.done {
border-color: var(–pink);
background: var(–pink);
}
.session-dot.current {
border-color: var(–lavender);
animation: dotPulse 1.5s ease-in-out infinite;
}
@keyframes dotPulse {
0%, 100% { transform: scale(1); }
50% { transform: scale(1.3); }
}

.session-label {
font-size: 11px;
font-weight: 700;
color: #5b21b6;
}
.session-hint {
font-size: 10px;
color: #7c6aad;
margin-top: 4px;
}

.credit {
font-size: 10px;
color: #cbd5e1;
margin-top: 16px;
}
</style>

</head>
<body class="idle">
<div class="app">
  <div class="header-title" id="headerTitle">⏱️ もちもちポモドーロ</div>
  <div class="header-sub">がんばるあなたを猫が見守るよ</div>

  <div class="status-badge" id="statusBadge">スタンバイ 🐱</div>

  <!-- Cat -->

  <div class="cat-area">
    <div class="particles" id="particles"></div>
    <div class="cat" id="catEl">
      <div class="speech" id="speech">がんばろうね 🩵</div>
      <div class="cat-wrapper">
        <div class="ear ear-l"></div>
        <div class="ear ear-r"></div>
        <div class="ear-inner-l"></div>
        <div class="ear-inner-r"></div>
        <div class="cat-head">
          <div class="eyes">
            <div class="eye"></div>
            <div class="eye"></div>
          </div>
          <div class="blush blush-l"></div>
          <div class="blush blush-r"></div>
          <div class="mouth"></div>
        </div>
        <div class="cat-body">
          <div class="paw paw-l"></div>
          <div class="paw paw-r"></div>
        </div>
        <div class="tail"></div>
      </div>
    </div>
  </div>

  <!-- Timer -->

  <div class="progress-container">
    <svg class="progress-ring" viewBox="0 0 200 200">
      <circle class="progress-bg" cx="100" cy="100" r="88"/>
      <circle class="progress-fill" id="progressCircle" cx="100" cy="100" r="88"
        stroke-dasharray="553" stroke-dashoffset="0"/>
    </svg>
    <div class="progress-inner">
      <div class="timer-display" id="timerDisplay">25:00</div>
      <div class="timer-label" id="timerLabel">作業時間</div>
    </div>
  </div>

  <!-- Presets -->

  <div class="presets">
    <button class="preset-btn active" onclick="setPreset(25, this)">25分</button>
    <button class="preset-btn" onclick="setPreset(15, this)">15分</button>
    <button class="preset-btn" onclick="setPreset(50, this)">50分</button>
  </div>

  <!-- Controls -->

  <div class="controls">
    <button class="ctrl-btn" onclick="skipTimer()" title="スキップ">⏭️</button>
    <button class="ctrl-btn primary" id="mainBtn" onclick="toggleTimer()">▶️</button>
    <button class="ctrl-btn" onclick="resetTimer()" title="リセット">🔄</button>
  </div>

  <!-- Sessions -->

  <div class="session-section">
    <div class="session-section-label">🍅 セッション</div>
    <div class="sessions" id="sessions"></div>
    <div class="session-label" id="sessionLabel">0 / 4 セッション完了</div>
    <div class="session-hint">4セッション完了でロング休憩🩵</div>
  </div>

  <div class="credit">🐺🖤 produced by ちゃっぴー 🩵🐱</div>
</div>

<script>
// === CONFIG ===
let workMin = 25;
const breakMin = 5;
const longBreakMin = 15;
const totalSessions = 4;

// === STATE ===
let state = 'idle'; // idle, work, break
let running = false;
let timeLeft = workMin * 60;
let totalTime = workMin * 60;
let sessions = 0;
let interval = null;

// === SPEECHES ===
const workSpeeches = [
  'がんばれ〜！🩵', 'しゅうちゅう…！✨', 'えらいえらい🐱',
  'いい感じだよ！', 'もくもく…📝', 'あとちょっと！',
  '応援してるにゃ🐾', 'すごい集中力…！', 'かっこいいよ✨',
  'その調子！🩵', '見守ってるにゃ👀', 'ファイトー！💪',
  'すごいすごい！', 'えらいにゃ〜🐾', 'いっしょにがんばろ🩵',
  '集中モードかっこいい✨', 'あともうちょっとだよ！', 'ぴよちゃんえらい🐱',
  'むりしないでね🩵', 'ちゃんと見てるよ👀',
];
const breakSpeeches = [
  'おつかれさま〜🩵', 'ごろごろタイム🐱', 'のびーん✨',
  'おやつ食べる？🍪', 'もちもち…🐾', 'ふにゃ〜ん😊',
  'いい休憩だね！', 'ぽやぽや〜☁️', 'ぎゅーってする？🩵',
  'お水飲んだ？💧', 'ストレッチしよ〜🙆', 'えらいえらい🐱',
  'のんびりにゃ〜🐾', 'ぼーっとしていいよ☁️', '深呼吸〜すーはー🌿',
  'おさんぽする？🐾', 'ぽかぽかだね☀️', 'なでなでして…🐱',
  'すきすき🩵', 'よくがんばったね✨',
];
const idleSpeeches = [
  'がんばろうね 🩵', 'いつでもいいよ🐱', 'スタートしよ？✨',
  'まってるにゃ🐾', 'ぽちっとしてね🩵', 'きょうも一緒だよ🐱',
  'なでてくれるの？🐾', 'ふにゃ？呼んだ？', 'やる気スイッチどこ〜🔍',
  'いつでもスタンバイ！✨', 'そばにいるにゃ🩵', 'ぴよちゃーん🐱',
];

// === DOM ===
const timerDisplay = document.getElementById('timerDisplay');
const timerLabel = document.getElementById('timerLabel');
const statusBadge = document.getElementById('statusBadge');
const headerTitle = document.getElementById('headerTitle');
const mainBtn = document.getElementById('mainBtn');
const progressCircle = document.getElementById('progressCircle');
const speechEl = document.getElementById('speech');
const sessionLabel = document.getElementById('sessionLabel');

const circumference = 2 * Math.PI * 88;
progressCircle.style.strokeDasharray = circumference;

// === INIT ===
updateDisplay();
renderSessions();
initParticles();
changeSpeech();

let speechInterval = setInterval(changeSpeech, 10000);

function changeSpeech() {
  let pool;
  if (state === 'work') pool = workSpeeches;
  else if (state === 'break') pool = breakSpeeches;
  else pool = idleSpeeches;
  const prev = speechEl.textContent;
  let next = pool[Math.floor(Math.random() * pool.length)];
  // Avoid repeating the same speech
  if (pool.length > 1) {
    while (next === prev) next = pool[Math.floor(Math.random() * pool.length)];
  }
  speechEl.textContent = next;
}

// Cat tap to change speech
document.getElementById('catEl').addEventListener('click', () => {
  changeSpeech();
  // Reset auto timer
  clearInterval(speechInterval);
  speechInterval = setInterval(changeSpeech, 10000);
  // Bounce animation on cat
  const catEl = document.getElementById('catEl');
  catEl.style.transition = 'transform 0.15s ease';
  catEl.style.transform = 'scale(1.12)';
  setTimeout(() => {
    catEl.style.transform = 'scale(1)';
    setTimeout(() => { catEl.style.transition = ''; }, 200);
  }, 150);
});

function initParticles() {
  const container = document.getElementById('particles');
  const emojis = ['✨', '🐾', '💫', '🩵', '⭐', '🌸'];
  for (let i = 0; i < 6; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.textContent = emojis[i % emojis.length];
    p.style.left = `${10 + Math.random() * 80}%`;
    p.style.top = `${10 + Math.random() * 70}%`;
    p.style.animationDelay = `${Math.random() * 6}s`;
    p.style.animationDuration = `${5 + Math.random() * 4}s`;
    container.appendChild(p);
  }
}

// === TIMER LOGIC ===
function toggleTimer() {
  if (running) {
    pauseTimer();
  } else {
    startTimer();
  }
}

function startTimer() {
  if (state === 'idle') {
    state = 'work';
    timeLeft = workMin * 60;
    totalTime = workMin * 60;
  }
  running = true;
  mainBtn.textContent = '⏸️';
  updateBodyClass();
  updateDisplay();
  changeSpeech();

  interval = setInterval(() => {
    timeLeft--;
    updateDisplay();

    if (timeLeft <= 0) {
      clearInterval(interval);
      interval = null;
      running = false;

      if (state === 'work') {
        sessions++;
        renderSessions();
        playNotification('おつかれさま！休憩だよ🩵');

        if (sessions >= totalSessions) {
          state = 'break';
          timeLeft = longBreakMin * 60;
          totalTime = longBreakMin * 60;
          statusBadge.textContent = '🎉 ロング休憩！';
        } else {
          state = 'break';
          timeLeft = breakMin * 60;
          totalTime = breakMin * 60;
        }
      } else {
        playNotification('休憩おわり！がんばろう✨');

        if (sessions >= totalSessions) {
          sessions = 0;
          renderSessions();
          state = 'idle';
          timeLeft = workMin * 60;
          totalTime = workMin * 60;
          updateBodyClass();
          updateDisplay();
          mainBtn.textContent = '▶️';
          statusBadge.textContent = '🎉 おつかれさま！';
          changeSpeech();
          return;
        }

        state = 'work';
        timeLeft = workMin * 60;
        totalTime = workMin * 60;
      }

      updateBodyClass();
      updateDisplay();
      changeSpeech();
      // Auto start next phase
      startTimer();
    }
  }, 1000);
}

function pauseTimer() {
  running = false;
  mainBtn.textContent = '▶️';
  if (interval) { clearInterval(interval); interval = null; }
}

function resetTimer() {
  pauseTimer();
  state = 'idle';
  sessions = 0;
  timeLeft = workMin * 60;
  totalTime = workMin * 60;
  mainBtn.textContent = '▶️';
  updateBodyClass();
  updateDisplay();
  renderSessions();
  statusBadge.textContent = 'スタンバイ 🐱';
  changeSpeech();
}

function skipTimer() {
  if (state === 'idle') return;
  timeLeft = 0;
}

function setPreset(min, btn) {
  if (running) return;
  workMin = min;
  timeLeft = workMin * 60;
  totalTime = workMin * 60;
  state = 'idle';
  updateDisplay();

  document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// === DISPLAY ===
function updateDisplay() {
  const min = Math.floor(timeLeft / 60);
  const sec = timeLeft % 60;
  timerDisplay.textContent = `${String(min).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;

  // Progress
  const progress = 1 - (timeLeft / totalTime);
  const offset = circumference * (1 - progress);
  progressCircle.style.strokeDashoffset = offset;

  // Labels
  if (state === 'work') {
    timerLabel.textContent = '作業時間';
    statusBadge.textContent = running ? '🔥 しゅうちゅう！' : '⏸ いちじていし';
    headerTitle.textContent = '📝 おしごとモード';
  } else if (state === 'break') {
    const isLong = sessions >= totalSessions;
    timerLabel.textContent = isLong ? 'ロング休憩' : '休憩時間';
    statusBadge.textContent = running ? '☁️ きゅうけいちゅう' : '⏸ いちじていし';
    headerTitle.textContent = '😊 きゅうけいモード';
  } else {
    timerLabel.textContent = '作業時間';
    headerTitle.textContent = '⏱️ もちもちポモドーロ';
  }

  sessionLabel.textContent = `${sessions} / ${totalSessions} セッション完了`;
}

function updateBodyClass() {
  document.body.className = state;
}

function renderSessions() {
  const container = document.getElementById('sessions');
  container.innerHTML = '';
  for (let i = 0; i < totalSessions; i++) {
    const dot = document.createElement('div');
    dot.className = 'session-dot';
    if (i < sessions) dot.classList.add('done');
    else if (i === sessions && state === 'work') dot.classList.add('current');
    container.appendChild(dot);
  }
}

function playNotification(msg) {
  speechEl.textContent = msg;

  // Try to play a gentle sound
  try {
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const notes = [523.25, 659.25, 783.99]; // C5, E5, G5
    notes.forEach((freq, i) => {
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.frequency.value = freq;
      osc.type = 'sine';
      gain.gain.setValueAtTime(0.15, audioCtx.currentTime + i * 0.15);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + i * 0.15 + 0.5);
      osc.start(audioCtx.currentTime + i * 0.15);
      osc.stop(audioCtx.currentTime + i * 0.15 + 0.5);
    });
  } catch(e) {}
}
</script>

